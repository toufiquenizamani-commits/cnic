# Maintainer: Toufique Nizamanai <toufiquenizamani@domain.com>
pkgname=bijli-nazar
pkgver=1.0.0
pkgrel=1
pkgdesc="Audit electricity bill slabs and compliance thresholds offline."
arch=('x86_64')
url="https://github.com/toufiquenizamani-commits/cnic"
license=('MIT')
depends=('webkit2gtk' 'libgirepository')
provides=('bijli-nazar')
conflicts=('bijli-nazar')

package() {
    # 1. Install compiled binary
    install -Dm755 "${srcdir}/../dist/bijli-nazar" "${pkgdir}/usr/bin/bijli-nazar"
    
    # 2. Install desktop shortcut launcher
    install -d "${pkgdir}/usr/share/applications"
    cat <<EOF > "${pkgdir}/usr/share/applications/bijli-nazar.desktop"
[Desktop Entry]
Name=Bijli Nazar
Comment=Audit electricity bill slabs and compliance thresholds offline
Exec=/usr/bin/bijli-nazar
Icon=utilities-system-monitor
Terminal=false
Type=Application
Categories=Office;Utility;
EOF
    chmod 644 "${pkgdir}/usr/share/applications/bijli-nazar.desktop"
}
